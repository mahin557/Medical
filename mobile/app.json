{
  "expo": {
    "name": "MedDx",
    "slug": "meddx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meddx.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.meddx.app"
    },
    "scheme": "meddx",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ]
  }
}
